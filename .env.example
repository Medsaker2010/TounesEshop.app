# Stripe Keys
STRIPE_SECRET_KEY=sk_test_YOUR_SECRET_KEY
STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=whsec_YOUR_WEBHOOK_SECRET

# App URL (no trailing slash)
BASE_URL=https://your-domain.com

# Port
PORT=4242

# Admin email (bypass payment for this address)
ADMIN_EMAIL=admin@your-domain.com

# Timezone (for expiry display)
TZ=Africa/Tunis

# Provider API Keys (one per server panel)
API_KEY_STRONG8K=YOUR_STRONG8K_API_KEY
API_KEY_NEO4K=YOUR_NEO4K_API_KEY
API_KEY_NEXON4K=YOUR_NEXON4K_API_KEY
API_KEY_FUEGOTV=YOUR_FUEGOTV_API_KEY
API_KEY_EAGLE4K=YOUR_EAGLE4K_API_KEY
API_KEY_DINOVIP=YOUR_DINOVIP_API_KEY
