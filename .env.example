# Configuration de Paiement Stripe
STRIPE_SECRET_KEY=sk_test_51... (Remplacez par votre Secret Key)
STRIPE_PUBLISHABLE_KEY=pk_test_51... (Remplacez par votre Publishable Key)
STRIPE_WEBHOOK_SECRET=whsec_... (Remplacez par votre Webhook Secret)

# Configuration du Serveur (Pas de slash à la fin)
BASE_URL=https://yourtvsat.com
PORT=4242

# Administration
ADMIN_EMAIL=admin@yourtvsat.com

# Fuseau Horaire
TZ=Africa/Tunis

# API Keys des Serveurs IPTV (Remplacez les "YOUR_..." par vos vraies clés)
API_KEY_STRONG8K=VOTRE_CLE_STRONG8K
API_KEY_NEO4K=VOTRE_CLE_NEO4K
API_KEY_NEXON4K=VOTRE_CLE_NEXON4K
API_KEY_FUEGOTV=VOTRE_CLE_FUEGOTV
API_KEY_EAGLE4K=VOTRE_CLE_EAGLE4K
API_KEY_DINOVIP=VOTRE_CLE_DINOVIP
